    <bpmn2:participant id="Apertura_excepcional_materias" name="Apertura excepcional materias" processRef="Apertura_excepcional_de_materias" bizuit:AttachmentsCollection="[]" />
    <bpmn2:textAnnotation id="Muestra_instancias_agrupadas_x_materia_para_analisis_masivo">
      <bpmn2:text>Muestra instancias agrupadas x materia para análisis masivo</bpmn2:text>
    </bpmn2:textAnnotation>
    <bpmn2:textAnnotation id="MECA_da_el_ok_solo_si_se_debe_adelantar_el_periodo_de_una_materia_pero_no_si_es_algo_ya_dictado_xq_no_se_modifica_contenido">
      <bpmn2:text>MECA da el ok solo si se debe adelantar el período de una materia, pero no si es algo ya dictado xq no se modifica contenido</bpmn2:text>
    </bpmn2:textAnnotation>
    <bpmn2:textAnnotation id="SGA_da_ok_para_disponibilidad_de_docentes">
      <bpmn2:text>SGA da ok para disponibilidad de docentes</bpmn2:text>
    </bpmn2:textAnnotation>
    <bpmn2:textAnnotation id="Ver_si_es_factible_comunicar_a_otros_alumnos_q_tambien_estuvieran_en_condiciones_de_cursarla_por_mas_q_no_hayan_solicitado">
      <bpmn2:text>Ver si es factible comunicar a otros alumnos q también estuvieran en condiciones de cursarla por más q no hayan solicitado</bpmn2:text>
    </bpmn2:textAnnotation>
    <bpmn2:textAnnotation id="correlativas_regularizadas_o_aprobadas_2_semanas_antes_del_inicio_del_cursado_materia_dictada_al_menos_un_periodo_previo_bimestrales_no_se_pueden_abrir_en_el_bimestre_inmediato_posterior">
      <bpmn2:text>- correlativas regularizadas o aprobadas
- 2 semanas antes del inicio del cursado
- materia dictada al menos un período previo
- bimestrales no se pueden abrir en el bimestre inmediato posterior</bpmn2:text>
    </bpmn2:textAnnotation>
    <bpmn2:association id="Association_0hkdwje" associationDirection="None" sourceRef="Solicitar_apertura" targetRef="correlativas_regularizadas_o_aprobadas_2_semanas_antes_del_inicio_del_cursado_materia_dictada_al_menos_un_periodo_previo_bimestrales_no_se_pueden_abrir_en_el_bimestre_inmediato_posterior" />
