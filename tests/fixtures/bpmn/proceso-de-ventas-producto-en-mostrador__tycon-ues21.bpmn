        <bpmn2:targetRef>DataStoreReference_1vygoyp</bpmn2:targetRef>
      </bpmn2:dataOutputAssociation>
    </bpmn2:userTask>
    <bpmn2:manualTask id="Activity_1rquu9z" name="Entregar original de factura con sello de &#34;pagado&#34;" bizuit:Performers="Responsable de Cobros" bizuit:Accountable="Administración" bizuit:Informed="Gerente de Administración y Finanzas">
      <bpmn2:documentation>Se entrega al Responsable de Entrega, el formulario de factura en original con sello de "pagado" como constancia de que se recibió el dinero del cliente.</bpmn2:documentation>
      <bpmn2:incoming>Flow_1vj65ll</bpmn2:incoming>
      <bpmn2:outgoing>Flow_1kbfysm</bpmn2:outgoing>
    </bpmn2:manualTask>
    <bpmn2:userTask id="Activity_0eefz0z" name="Receptar factura a cobrar" bizuit:Performers="Responsable de Cobros" bizuit:Accountable="Administración" bizuit:Informed="Gerente de Administración y Finanzas">
      <bpmn2:documentation>El responsable de cobro, recibe la factura del responsable de ventas, para proceder a cobrar.</bpmn2:documentation>
      <bpmn2:incoming>Flow_0is7bnh</bpmn2:incoming>
      <bpmn2:incoming>Flow_19b9hz7</bpmn2:incoming>
      <bpmn2:outgoing>Flow_1mlci6m</bpmn2:outgoing>
    </bpmn2:userTask>
    <bpmn2:userTask id="Activity_0i350tg" name="Receptar Factura" bizuit:Performers="Responsable de Entrega" bizuit:Accountable="Administración" bizuit:Informed="Gerente de Administración y Finanzas">
      <bpmn2:documentation>Se recibe la factura en original.</bpmn2:documentation>
      <bpmn2:incoming>Flow_1kbfysm</bpmn2:incoming>
      <bpmn2:outgoing>Flow_0qzlwr6</bpmn2:outgoing>
    </bpmn2:userTask>
    <bpmn2:userTask id="Activity_0v0q6bn" name="Controlar si la factura fue cobrada" bizuit:Performers="Responsable de Entrega" bizuit:Accountable="Administración" bizuit:Informed="Gerente de Administración y Finanzas">
      <bpmn2:documentation>Se verifica si la factura fue cobrada, para ello se valida en almacén Cobros.</bpmn2:documentation>
      <bpmn2:incoming>Flow_0qzlwr6</bpmn2:incoming>
      <bpmn2:outgoing>Flow_0s6yulq</bpmn2:outgoing>
      <bpmn2:property id="Property_1s6fjkq" name="__targetRef_placeholder" />
      <bpmn2:dataInputAssociation id="DataInputAssociation_0ywsgyu">
        <bpmn2:sourceRef>DataStoreReference_1m8snby</bpmn2:sourceRef>
        <bpmn2:targetRef>Property_1s6fjkq</bpmn2:targetRef>
      </bpmn2:dataInputAssociation>
    </bpmn2:userTask>
    <bpmn2:manualTask id="Activity_084w8p0" name="Indicar al cliente pasar por Caja" bizuit:Performers="Responsable de Entrega" bizuit:Informed="Gerente de Administración y Finanzas">
      <bpmn2:documentation>Si la factura no tiene sello, se envia la misma a la actividad Receptar Factura a Cobrar.</bpmn2:documentation>
      <bpmn2:incoming>Flow_1pug19e</bpmn2:incoming>
      <bpmn2:outgoing>Flow_19b9hz7</bpmn2:outgoing>
    </bpmn2:manualTask>
    <bpmn2:manualTask id="Activity_04btyb3" name="Controlar la factura con lo que hay en el montacarga" bizuit:Performers="Responsable de Entrega" bizuit:Informed="Gerente de Administración y Finanzas">
      <bpmn2:documentation>Si la factura tiene sello, se controla dicho documento contra el producto ubicado en el montacargas.</bpmn2:documentation>
      <bpmn2:incoming>Flow_1m3vws7</bpmn2:incoming>
      <bpmn2:outgoing>Flow_06ao3ut</bpmn2:outgoing>
    </bpmn2:manualTask>
    <bpmn2:manualTask id="Activity_1t17bgt" name="Llevar mueble a venta" bizuit:Performers="Responsable de Entrega" bizuit:Informed="Gerente de Administración y Finanzas">
      <bpmn2:documentation>Si el mueble no corresponde, se envia el mismo al Reponsable de Ventas para que valide el mueble correspondiente.</bpmn2:documentation>
      <bpmn2:incoming>Flow_0nzpse1</bpmn2:incoming>
      <bpmn2:outgoing>Flow_1lnocwl</bpmn2:outgoing>
    </bpmn2:manualTask>
    <bpmn2:userTask id="Activity_1utjtoe" name="Solicitar el mueble correcto" bizuit:Performers="Responsable de Entrega" bizuit:Accountable="Administración" bizuit:Informed="Gerente de Administración y Finanzas">
      <bpmn2:documentation>Se pide el mueble que corresponde a la factura.</bpmn2:documentation>
      <bpmn2:incoming>Flow_1lnocwl</bpmn2:incoming>
      <bpmn2:outgoing>Flow_18swea6</bpmn2:outgoing>
    </bpmn2:userTask>
    <bpmn2:userTask id="Activity_1e55p04" name="Registrar entrega del mueble" bizuit:Performers="Responsable de Entrega" bizuit:Accountable="Administración" bizuit:Informed="Gerente de Administración y Finanzas">
      <bpmn2:documentation>Si el mueble es el correcto, se registra la entrega del mismo y se guardan los datos en el almacén Entregas.</bpmn2:documentation>
      <bpmn2:incoming>Flow_15p2y74</bpmn2:incoming>
      <bpmn2:incoming>Flow_1tv8s4z</bpmn2:incoming>
      <bpmn2:outgoing>Flow_0qdxd4s</bpmn2:outgoing>
      <bpmn2:dataOutputAssociation id="DataOutputAssociation_16ctge6">
        <bpmn2:targetRef>DataStoreReference_0316hhs</bpmn2:targetRef>
      </bpmn2:dataOutputAssociation>
    </bpmn2:userTask>
    <bpmn2:manualTask id="Activity_1h5tp7p" name="Sellar factura como &#34;entregado&#34;" bizuit:Performers="Responsable de Entrega" bizuit:Informed="Gerente de Administración y Finanzas">
      <bpmn2:documentation>Una vez registrada la entrega, se sella el documento factura como "Entregado".</bpmn2:documentation>
      <bpmn2:incoming>Flow_0qdxd4s</bpmn2:incoming>
      <bpmn2:outgoing>Flow_0lwvkec</bpmn2:outgoing>
    </bpmn2:manualTask>
    <bpmn2:manualTask id="Activity_0poz6v6" name="Entregar mueble y factura sellada" bizuit:Performers="Responsable de Entrega" bizuit:Informed="Gerente de Administración y Finanzas">
      <bpmn2:documentation>Se entrega al clente el mueble y la factura original con sello.</bpmn2:documentation>
      <bpmn2:incoming>Flow_0lwvkec</bpmn2:incoming>
      <bpmn2:outgoing>Flow_14o4am1</bpmn2:outgoing>
    </bpmn2:manualTask>
    <bpmn2:userTask id="Activity_0sh7rz5" name="Entregar el mueble correcto" bizuit:Performers="Responsable de Ventas" bizuit:Accountable="Administración" bizuit:Informed="Gerente de Administración y Finanzas">
      <bpmn2:documentation>El responsable de ventas, verifica el pedido de mueble correspondiente a la factura, validando contra el almacén Muebles.</bpmn2:documentation>
      <bpmn2:incoming>Flow_18swea6</bpmn2:incoming>
      <bpmn2:outgoing>Flow_1tv8s4z</bpmn2:outgoing>
