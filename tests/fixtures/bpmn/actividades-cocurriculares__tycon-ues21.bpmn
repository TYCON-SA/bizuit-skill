    <bpmn2:userTask id="_3_Espera_Confirmacion_Postulante" name="3- Espera Confirmacion Postulante" bizuit:Performers="ACC_ControlRequisitos" bizuit:AttachmentsCollection="[]" bizuit:Accountable="" bizuit:Consulted="" bizuit:Informed="">
      <bpmn2:documentation>&lt;div&gt;Las postulaciones que fueron seleccionadas y les fue asignada una ayudantía,&lt;/div&gt;&lt;div&gt;se muestran en la bandeja “Espera Confirmación Postulante”.&lt;br&gt;&lt;div&gt;1. Pestaña bandeja “Espera Confirmación Postulante”.&lt;/div&gt;&lt;div&gt;2. Nombre actividad.&lt;/div&gt;&lt;div&gt;3. Instancia de postulación que fue asignada y espera la confirmación del&amp;nbsp;&lt;span style="font-size: 14px;"&gt;alumno.&lt;/span&gt;&lt;/div&gt;&lt;div&gt;Cuando el Postulante acepta la asignación, presionando en el mail&amp;nbsp;&lt;span style="font-size: 14px;"&gt;recibido la opción "Validar", la postulación pasa a la bandeja “Confirmar&amp;nbsp;&lt;/span&gt;&lt;span style="font-size: 14px;"&gt;Acción HR” de Revisión y Cumplimiento de Requisitos Postulantes.&amp;nbsp;&lt;/span&gt;&lt;span style="font-size: 14px;"&gt;Cuando el Postulante Rechaza la asignación, presionando en el mail&amp;nbsp;&lt;/span&gt;&lt;span style="font-size: 14px;"&gt;recibido la opción "Rechazar", la postulación vuelve a la bandeja “Proceso&amp;nbsp;&lt;/span&gt;&lt;span style="font-size: 14px;"&gt;Selección y Asignación de Postulantes” de Selección de Postulantes y a&amp;nbsp;&lt;/span&gt;&lt;span style="font-size: 14px;"&gt;la bandeja “En espera de Selección” de control de requisitos.&lt;/span&gt;&lt;/div&gt;&lt;/div&gt;</bpmn2:documentation>
      <bpmn2:incoming>Flow_0db0edx</bpmn2:incoming>
      <bpmn2:outgoing>Flow_1l2owbw</bpmn2:outgoing>
    </bpmn2:userTask>
    <bpmn2:sequenceFlow id="Flow_0j28xe6" sourceRef="Borrar_Notas" targetRef="Acc_FInalizados" />
