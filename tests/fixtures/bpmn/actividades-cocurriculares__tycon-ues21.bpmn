    <bpmn2:participant id="Actividades_Cocurriculares" name="Actividades Cocurriculares" processRef="Process_1" bizuit:AttachmentsCollection="[]">
      <bpmn2:documentation>&lt;div&gt;&lt;b&gt;Objetivo&lt;/b&gt;&lt;/div&gt;&lt;div&gt;Este documento describe la gestión de la Actividad Extracurricular Ayudantía en&lt;/div&gt;&lt;div&gt;Docencia de Universidad Siglo 21.&lt;/div&gt;&lt;div&gt;&lt;b&gt;Alcance&lt;/b&gt;&lt;/div&gt;&lt;div&gt;El documento explica los pasos desde el proceso de Postulación y Revisión de&lt;/div&gt;&lt;div&gt;requisitos, hasta la Selección de los Aspirantes para Ayudantía en Docencia,&lt;/div&gt;&lt;div&gt;así como también la configuración de parámetros que involucran estos&lt;/div&gt;&lt;div&gt;procesos.&lt;/div&gt;</bpmn2:documentation>
    </bpmn2:participant>
    <bpmn2:textAnnotation id="Notificar_Alumno">
