    <bpmn2:sequenceFlow id="Flow_1vz7r38" sourceRef="Solicitud_actividad" targetRef="Ingresar_solicitud_de_actividad_Cocurricular" />
    <bpmn2:startEvent id="Solicitud_actividad" name="Solicitud actividad" bizuit:Performers="CoDocente" bizuit:AttachmentsCollection="[]" bizuit:Accountable="" bizuit:Consulted="" bizuit:Informed="">
      <bpmn2:documentation>&lt;div&gt;Postulación&lt;/div&gt;&lt;div&gt;Paso 1 – Acceso a SGU&lt;/div&gt;&lt;div&gt;El Alumno ingresa a través del Sistema de Gestión Universitaria (SGU), el cual solicita&lt;/div&gt;&lt;div&gt;registrarse con Usuario, Documento y Contraseña.&lt;br&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;</bpmn2:documentation>
      <bpmn2:outgoing>Flow_1vz7r38</bpmn2:outgoing>
    </bpmn2:startEvent>
    <bpmn2:userTask id="Ingresar_solicitud_de_actividad_Cocurricular" name="Ingresar solicitud de actividad Cocurricular" bizuit:Performers="CoDocente" bizuit:AttachmentsCollection="[]" bizuit:Accountable="" bizuit:Consulted="" bizuit:Informed="">
      <bpmn2:documentation>&lt;div&gt;Paso 2 – Inscripción a Actividades&lt;/div&gt;&lt;div&gt;Una vez registrado en el SGU se nos muestra el formulario de inscripción a&lt;/div&gt;&lt;div&gt;Actividades.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;En él se pueden observar los siguientes elementos:&lt;/div&gt;&lt;div&gt;1. Datos del alumno.&lt;/div&gt;&lt;div&gt;a. Nombre y Apellido.&lt;/div&gt;&lt;div&gt;b. Documento.&lt;/div&gt;&lt;div&gt;c. Carrera.&lt;/div&gt;&lt;div&gt;d. Email y Teléfono&lt;/div&gt;&lt;div&gt;2. Agrupadores.&lt;/div&gt;&lt;div&gt;Este combo muestra agrupadores que permiten filtrar actividades&lt;/div&gt;&lt;div&gt;del mismo tipo.&lt;/div&gt;&lt;div&gt;3. Actividades.&lt;/div&gt;&lt;div&gt;En este combo se debe seleccionar la actividad Ayudantía en&lt;/div&gt;&lt;div&gt;Docencia – VAED.&lt;/div&gt;&lt;div&gt;4. Enlace a requisitos para inscripción en la actividad.&lt;/div&gt;&lt;div&gt;5. Comentarios.&lt;/div&gt;&lt;div&gt;6. Adjuntos.&lt;/div&gt;&lt;div&gt;Una vez ingresados los datos necesarios, se habilita el botón la postulación.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Paso 3 – Notificación de envío&lt;/div&gt;&lt;div&gt;Sitio Web&lt;/div&gt;&lt;div&gt;A continuación, en el mismo sitio web se muestra un mensaje que confirma el&lt;/div&gt;&lt;div&gt;envío de la postulación.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;</bpmn2:documentation>
      <bpmn2:incoming>Flow_1vz7r38</bpmn2:incoming>
      <bpmn2:outgoing>Flow_1dqikwa</bpmn2:outgoing>
    </bpmn2:userTask>
