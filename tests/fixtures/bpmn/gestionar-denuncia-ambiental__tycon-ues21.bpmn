<?xml version="1.0" encoding="UTF-8"?>
<bpmn2:definitions xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bpmn2="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:bizuit="http://tycon.com/schema/bpmn/bizuit" xmlns:bioc="http://bpmn.io/schema/bpmn/biocolor/1.0" xmlns:color="http://www.omg.org/spec/BPMN/non-normative/color/1.0" id="sample-diagram" targetNamespace="http://bpmn.io/schema/bpmn" xsi:schemaLocation="http://www.omg.org/spec/BPMN/20100524/MODEL BPMN20.xsd">
  <bpmn2:collaboration id="Collaboration_150wd7z">
    <bpmn2:participant id="Gestionar_Denuncia_Ambiental" name="Gestionar Denuncia Ambiental" processRef="Process_1" bizuit:AttachmentsCollection="[]">
      <bpmn2:documentation>&lt;p data-start="0" data-end="401"&gt;Un &lt;strong data-start="3" data-end="47"&gt;proceso de gestión de denuncia ambiental&lt;/strong&gt; es un conjunto de actividades estructuradas que permiten &lt;strong data-start="105" data-end="167"&gt;recibir, evaluar, investigar, resolver y hacer seguimiento&lt;/strong&gt; a denuncias relacionadas con impactos, daños o irregularidades ambientales. Este proceso lo implementan generalmente organismos gubernamentales, municipios, empresas con responsabilidad ambiental, u organizaciones no gubernamentales.&lt;/p&gt;
&lt;h3 data-start="403" data-end="425"&gt;Objetivo principal&lt;/h3&gt;
&lt;p data-start="426" data-end="637"&gt;Atender y resolver denuncias ambientales de forma &lt;strong data-start="476" data-end="536"&gt;efectiva, transparente y conforme a la normativa vigente&lt;/strong&gt;, protegiendo el medio ambiente y garantizando el derecho de las personas a vivir en un entorno sano.&lt;/p&gt;&lt;p data-start="426" data-end="637"&gt;Glosario:&lt;/p&gt;&lt;p data-start="426" data-end="637"&gt;Que es una denuncia&lt;/p&gt;&lt;p data-start="426" data-end="637"&gt;&lt;a href="https://www.cba.gov.ar/organismo/old-ministerio-de-educacion__trashed/institucional/" target="_blank"&gt;Institucional&lt;/a&gt;&lt;/p&gt;&lt;p data-start="426" data-end="637"&gt;&lt;br&gt;&lt;/p&gt;</bpmn2:documentation>
    </bpmn2:participant>
  </bpmn2:collaboration>
  <bpmn2:process id="Process_1" name="Gestionar Denuncia Ambiental" isExecutable="false" bizuit:ProcessLevel="1" bizuit:OrganizationId="TYCON-UES21">
    <bpmn2:laneSet id="LaneSet_16wcxv6">
      <bpmn2:lane id="PA_Responsable_Administrativo" name="PA- Responsable Administrativo" bizuit:Performers="PA- Responsable Administrativo" bizuit:Accountable="" bizuit:Consulted="" bizuit:Informed="" bizuit:AttachmentsCollection="[]">
        <bpmn2:flowNodeRef>Denuncia</bpmn2:flowNodeRef>
        <bpmn2:flowNodeRef>Registrar_Denuncia</bpmn2:flowNodeRef>
        <bpmn2:flowNodeRef>Notificar_inicio_de_gestion</bpmn2:flowNodeRef>
        <bpmn2:flowNodeRef>Verificar_Pertinencia_de_la_Denuncia</bpmn2:flowNodeRef>
        <bpmn2:flowNodeRef>Gateway_070r00o</bpmn2:flowNodeRef>
        <bpmn2:flowNodeRef>Cerrar_Denuncia_como_Improcedente</bpmn2:flowNodeRef>
        <bpmn2:flowNodeRef>Denuncia_improcedente</bpmn2:flowNodeRef>
        <bpmn2:flowNodeRef>Expediente_emitido</bpmn2:flowNodeRef>
        <bpmn2:flowNodeRef>Elevar_a_Legales</bpmn2:flowNodeRef>
        <bpmn2:flowNodeRef>Registrar_Expediente</bpmn2:flowNodeRef>
        <bpmn2:flowNodeRef>Gateway_1fkv6yp</bpmn2:flowNodeRef>
      </bpmn2:lane>
      <bpmn2:lane id="Jefe" name="Jefe" bizuit:AttachmentsCollection="[]" bizuit:Performers="Jefe" bizuit:Accountable="PA- Responsable Administrativo" bizuit:Consulted="" bizuit:Informed="">
        <bpmn2:flowNodeRef>Asignar_denuncia_al_Inspector</bpmn2:flowNodeRef>
        <bpmn2:flowNodeRef>Notificar_Inspector_Asignado</bpmn2:flowNodeRef>
        <bpmn2:flowNodeRef>Firmar_expediente</bpmn2:flowNodeRef>
        <bpmn2:flowNodeRef>Autorizar_Inspeccion</bpmn2:flowNodeRef>
      </bpmn2:lane>
      <bpmn2:lane id="Inspector" name="Inspector" bizuit:Performers="Inspector" bizuit:Accountable="" bizuit:Consulted="" bizuit:Informed="" bizuit:AttachmentsCollection="[]">
        <bpmn2:flowNodeRef>Gateway_1xbejjt</bpmn2:flowNodeRef>
        <bpmn2:flowNodeRef>Confeccionar_acta_de_constatacion</bpmn2:flowNodeRef>
        <bpmn2:flowNodeRef>Verificar_delito</bpmn2:flowNodeRef>
        <bpmn2:flowNodeRef>Informar_situacion_a_JP</bpmn2:flowNodeRef>
      </bpmn2:lane>
    </bpmn2:laneSet>
    <bpmn2:startEvent id="Denuncia" name="Denuncia" bizuit:Performers="PA- Responsable Administrativo">
      <bpmn2:outgoing>Flow_054u3uo</bpmn2:outgoing>
    </bpmn2:startEvent>
    <bpmn2:sequenceFlow id="Flow_054u3uo" sourceRef="Denuncia" targetRef="Registrar_Denuncia" />
    <bpmn2:sequenceFlow id="Flow_0gl759g" sourceRef="Registrar_Denuncia" targetRef="Notificar_inicio_de_gestion" />
    <bpmn2:userTask id="Registrar_Denuncia" name="Registrar Denuncia" bizuit:Performers="PA- Responsable Administrativo" bizuit:AttachmentsCollection="[{&#34;type&#34;:&#34;file&#34;,&#34;content&#34;:&#34;&#34;,&#34;fileName&#34;:&#34;Apertura excepcional de materias.docx&#34;,&#34;descriptiveName&#34;:&#34;&#34;,&#34;mimeType&#34;:&#34;application/vnd.openxmlformats-officedocument.wordprocessingml.document&#34;,&#34;size&#34;:30474}]" bizuit:Accountable="" bizuit:Consulted="" bizuit:Informed="">
      <bpmn2:documentation>&lt;p data-start="679" data-end="707"&gt;&lt;strong data-start="679" data-end="707"&gt;Recepción de la denuncia&lt;/strong&gt;&lt;/p&gt;
&lt;ul data-start="711" data-end="915"&gt;
&lt;li data-start="711" data-end="785"&gt;
&lt;p data-start="713" data-end="785"&gt;Se puede realizar en forma presencial, telefónica, online o por escrito.&lt;/p&gt;
&lt;/li&gt;
&lt;li data-start="789" data-end="915"&gt;
&lt;p data-start="791" data-end="915"&gt;Se registran los datos del denunciante (puede ser anónima), fecha, tipo de afectación, ubicación, evidencia disponible, etc.&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;</bpmn2:documentation>
      <bpmn2:incoming>Flow_054u3uo</bpmn2:incoming>
      <bpmn2:outgoing>Flow_0gl759g</bpmn2:outgoing>
      <bpmn2:dataOutputAssociation id="DataOutputAssociation_0nr6hxr">
        <bpmn2:targetRef>Denuncias</bpmn2:targetRef>
      </bpmn2:dataOutputAssociation>
    </bpmn2:userTask>
    <bpmn2:sendTask id="Notificar_inicio_de_gestion" name="Notificar inicio de gestión" bizuit:Performers="PA- Responsable Administrativo">
      <bpmn2:incoming>Flow_0gl759g</bpmn2:incoming>
      <bpmn2:outgoing>Flow_00f1js5</bpmn2:outgoing>
    </bpmn2:sendTask>
    <bpmn2:sequenceFlow id="Flow_00f1js5" sourceRef="Notificar_inicio_de_gestion" targetRef="Verificar_Pertinencia_de_la_Denuncia" />
    <bpmn2:userTask id="Verificar_Pertinencia_de_la_Denuncia" name="Verificar Pertinencia de la Denuncia" bizuit:Performers="PA- Responsable Administrativo" bizuit:AttachmentsCollection="[]" bizuit:Accountable="" bizuit:Consulted="" bizuit:Informed="">
      <bpmn2:documentation>&lt;p data-start="920" data-end="942"&gt;&lt;strong data-start="920" data-end="942"&gt;Evaluación inicial&lt;/strong&gt;&lt;/p&gt;
&lt;ul data-start="946" data-end="1108"&gt;
&lt;li data-start="946" data-end="1052"&gt;
&lt;p data-start="948" data-end="1052"&gt;Se verifica la &lt;strong data-start="963" data-end="988"&gt;validez y competencia&lt;/strong&gt; del reclamo: ¿Es ambiental? ¿Le compete a la entidad receptora?&lt;/p&gt;
&lt;/li&gt;
&lt;li data-start="1056" data-end="1108"&gt;
&lt;p data-start="1058" data-end="1108"&gt;Se clasifica según &lt;strong data-start="1077" data-end="1107"&gt;nivel de riesgo o urgencia&lt;/strong&gt;.&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;</bpmn2:documentation>
      <bpmn2:incoming>Flow_00f1js5</bpmn2:incoming>
      <bpmn2:outgoing>Flow_0ezcex0</bpmn2:outgoing>
    </bpmn2:userTask>
    <bpmn2:exclusiveGateway id="Gateway_070r00o">
      <bpmn2:incoming>Flow_0ezcex0</bpmn2:incoming>
      <bpmn2:outgoing>No_es_pertinente</bpmn2:outgoing>
      <bpmn2:outgoing>Es_pertinente</bpmn2:outgoing>
    </bpmn2:exclusiveGateway>
    <bpmn2:sequenceFlow id="Flow_0ezcex0" sourceRef="Verificar_Pertinencia_de_la_Denuncia" targetRef="Gateway_070r00o" />
    <bpmn2:sequenceFlow id="No_es_pertinente" name="No es pertinente" sourceRef="Gateway_070r00o" targetRef="Gateway_1fkv6yp" />
    <bpmn2:sequenceFlow id="Flow_1x79px6" sourceRef="Gateway_1fkv6yp" targetRef="Cerrar_Denuncia_como_Improcedente" />
    <bpmn2:sequenceFlow id="Flow_1piff6x" sourceRef="Cerrar_Denuncia_como_Improcedente" targetRef="Denuncia_improcedente" />
    <bpmn2:sequenceFlow id="Es_pertinente" name="Es pertinente" sourceRef="Gateway_070r00o" targetRef="Asignar_denuncia_al_Inspector" />
    <bpmn2:userTask id="Asignar_denuncia_al_Inspector" name="Asignar denuncia al Inspector" bizuit:Performers="Jefe" bizuit:Accountable="PA- Responsable Administrativo" bizuit:AttachmentsCollection="[]" bizuit:Consulted="" bizuit:Informed="">
      <bpmn2:documentation>&lt;p data-start="1113" data-end="1143"&gt;&lt;strong data-start="1113" data-end="1143"&gt;Asignación y planificación&lt;/strong&gt;&lt;/p&gt;
&lt;ul data-start="1147" data-end="1312"&gt;
&lt;li data-start="1147" data-end="1213"&gt;
&lt;p data-start="1149" data-end="1213"&gt;Se designa un responsable o equipo técnico para atender el caso.&lt;/p&gt;
&lt;/li&gt;
&lt;li data-start="1217" data-end="1312"&gt;
&lt;p data-start="1219" data-end="1312"&gt;Se define un plan de investigación (visita, inspección, entrevistas, toma de muestras, etc.).&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;</bpmn2:documentation>
      <bpmn2:incoming>Es_pertinente</bpmn2:incoming>
      <bpmn2:outgoing>Flow_0q7arad</bpmn2:outgoing>
      <bpmn2:property id="Property_13re963" name="__targetRef_placeholder" />
      <bpmn2:dataInputAssociation id="DataInputAssociation_0qd12a6">
        <bpmn2:sourceRef>Inspectores</bpmn2:sourceRef>
        <bpmn2:targetRef>Property_13re963</bpmn2:targetRef>
      </bpmn2:dataInputAssociation>
    </bpmn2:userTask>
    <bpmn2:sequenceFlow id="Flow_0q7arad" sourceRef="Asignar_denuncia_al_Inspector" targetRef="Notificar_Inspector_Asignado" />
    <bpmn2:sendTask id="Notificar_Inspector_Asignado" name="Notificar Inspector Asignado" bizuit:Performers="Jefe" bizuit:Accountable="PA- Responsable Administrativo">
      <bpmn2:incoming>Flow_0q7arad</bpmn2:incoming>
      <bpmn2:outgoing>Flow_1ayrpd8</bpmn2:outgoing>
    </bpmn2:sendTask>
    <bpmn2:sequenceFlow id="Flow_1ayrpd8" sourceRef="Notificar_Inspector_Asignado" targetRef="Informar_situacion_a_JP" />
    <bpmn2:sequenceFlow id="Flow_0rk9gfz" sourceRef="Informar_situacion_a_JP" targetRef="Autorizar_Inspeccion" />
    <bpmn2:sequenceFlow id="Flow_0c6zlb3" sourceRef="Autorizar_Inspeccion" targetRef="Verificar_delito" />
    <bpmn2:sequenceFlow id="Flow_1ljjexl" sourceRef="Verificar_delito" targetRef="Gateway_1xbejjt" />
    <bpmn2:sequenceFlow id="Si_es_delito" name="Si es delito" sourceRef="Gateway_1xbejjt" targetRef="Confeccionar_acta_de_constatacion" />
    <bpmn2:sequenceFlow id="No_es_delito" name="No es delito" sourceRef="Gateway_1xbejjt" targetRef="Gateway_1fkv6yp" />
    <bpmn2:userTask id="Cerrar_Denuncia_como_Improcedente" name="Cerrar Denuncia como Improcedente" bizuit:Performers="PA- Responsable Administrativo">
      <bpmn2:incoming>Flow_1x79px6</bpmn2:incoming>
      <bpmn2:outgoing>Flow_1piff6x</bpmn2:outgoing>
    </bpmn2:userTask>
    <bpmn2:endEvent id="Denuncia_improcedente" name="Denuncia improcedente" bizuit:Performers="PA- Responsable Administrativo">
      <bpmn2:incoming>Flow_1piff6x</bpmn2:incoming>
    </bpmn2:endEvent>
    <bpmn2:sequenceFlow id="Flow_1muz9p0" sourceRef="Confeccionar_acta_de_constatacion" targetRef="Registrar_Expediente" />
    <bpmn2:sequenceFlow id="Flow_1oos7uq" sourceRef="Registrar_Expediente" targetRef="Firmar_expediente" />
    <bpmn2:sequenceFlow id="Flow_0wekakx" sourceRef="Firmar_expediente" targetRef="Elevar_a_Legales" />
    <bpmn2:sequenceFlow id="Flow_1vvkn66" sourceRef="Elevar_a_Legales" targetRef="Expediente_emitido" />
    <bpmn2:endEvent id="Expediente_emitido" name="Expediente emitido" bizuit:Performers="PA- Responsable Administrativo">
      <bpmn2:incoming>Flow_1vvkn66</bpmn2:incoming>
      <bpmn2:terminateEventDefinition id="TerminateEventDefinition_0gs289b" />
    </bpmn2:endEvent>
    <bpmn2:userTask id="Elevar_a_Legales" name="Elevar a Legales" bizuit:Performers="PA- Responsable Administrativo" bizuit:AttachmentsCollection="[]" bizuit:Accountable="" bizuit:Consulted="" bizuit:Informed="">
      <bpmn2:documentation>&lt;p data-start="1925" data-end="1940"&gt;&lt;strong data-start="1925" data-end="1940"&gt;Seguimiento&lt;/strong&gt;&lt;/p&gt;
&lt;ul data-start="1944" data-end="2080"&gt;
&lt;li data-start="1944" data-end="1997"&gt;
&lt;p data-start="1946" data-end="1997"&gt;Se verifica que las medidas correctivas se cumplan.&lt;/p&gt;
&lt;/li&gt;
&lt;li data-start="2001" data-end="2080"&gt;
&lt;p data-start="2003" data-end="2080"&gt;En casos graves, se continúa con monitoreo ambiental o sanciones adicionales.&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;</bpmn2:documentation>
      <bpmn2:incoming>Flow_0wekakx</bpmn2:incoming>
      <bpmn2:outgoing>Flow_1vvkn66</bpmn2:outgoing>
    </bpmn2:userTask>
    <bpmn2:userTask id="Firmar_expediente" name="Firmar expediente" bizuit:Performers="Jefe" bizuit:Accountable="PA- Responsable Administrativo" bizuit:AttachmentsCollection="[]" bizuit:Consulted="" bizuit:Informed="">
      <bpmn2:documentation>&lt;p data-start="1757" data-end="1773"&gt;&lt;strong data-start="1757" data-end="1773"&gt;Comunicación&lt;/strong&gt;&lt;/p&gt;
&lt;ul data-start="1777" data-end="1920"&gt;
&lt;li data-start="1777" data-end="1845"&gt;
&lt;p data-start="1779" data-end="1845"&gt;Se informa al denunciante sobre los resultados (si no es anónimo).&lt;/p&gt;
&lt;/li&gt;
&lt;li data-start="1849" data-end="1920"&gt;
&lt;p data-start="1851" data-end="1920"&gt;Se puede publicar un resumen en informes o portales de transparencia.&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;</bpmn2:documentation>
      <bpmn2:incoming>Flow_1oos7uq</bpmn2:incoming>
      <bpmn2:outgoing>Flow_0wekakx</bpmn2:outgoing>
    </bpmn2:userTask>
    <bpmn2:userTask id="Registrar_Expediente" name="Registrar Expediente" bizuit:Performers="PA- Responsable Administrativo">
      <bpmn2:incoming>Flow_1muz9p0</bpmn2:incoming>
      <bpmn2:outgoing>Flow_1oos7uq</bpmn2:outgoing>
      <bpmn2:dataOutputAssociation id="DataOutputAssociation_16kl4gc">
        <bpmn2:targetRef>Expedientes</bpmn2:targetRef>
      </bpmn2:dataOutputAssociation>
    </bpmn2:userTask>
    <bpmn2:exclusiveGateway id="Gateway_1fkv6yp">
      <bpmn2:incoming>No_es_pertinente</bpmn2:incoming>
      <bpmn2:incoming>No_es_delito</bpmn2:incoming>
      <bpmn2:outgoing>Flow_1x79px6</bpmn2:outgoing>
    </bpmn2:exclusiveGateway>
    <bpmn2:exclusiveGateway id="Gateway_1xbejjt">
      <bpmn2:incoming>Flow_1ljjexl</bpmn2:incoming>
      <bpmn2:outgoing>Si_es_delito</bpmn2:outgoing>
      <bpmn2:outgoing>No_es_delito</bpmn2:outgoing>
    </bpmn2:exclusiveGateway>
    <bpmn2:userTask id="Confeccionar_acta_de_constatacion" name="Confeccionar acta de constatación" bizuit:Performers="Inspector" bizuit:AttachmentsCollection="[]" bizuit:Accountable="" bizuit:Consulted="" bizuit:Informed="">
      <bpmn2:documentation>se aplican sanciones, se ordenan medidas</bpmn2:documentation>
      <bpmn2:incoming>Si_es_delito</bpmn2:incoming>
      <bpmn2:outgoing>Flow_1muz9p0</bpmn2:outgoing>
      <bpmn2:dataOutputAssociation id="DataOutputAssociation_1dh2o9s">
        <bpmn2:targetRef>Acta_de_Infraccion</bpmn2:targetRef>
      </bpmn2:dataOutputAssociation>
    </bpmn2:userTask>
    <bpmn2:userTask id="Autorizar_Inspeccion" name="Autorizar Inspección" bizuit:Performers="Jefe" bizuit:Accountable="PA- Responsable Administrativo">
      <bpmn2:incoming>Flow_0rk9gfz</bpmn2:incoming>
      <bpmn2:outgoing>Flow_0c6zlb3</bpmn2:outgoing>
    </bpmn2:userTask>
    <bpmn2:userTask id="Verificar_delito" name="Verificar delito" bizuit:Performers="Inspector" bizuit:AttachmentsCollection="[]" bizuit:Accountable="" bizuit:Consulted="" bizuit:Informed="">
      <bpmn2:documentation>&lt;p data-start="1537" data-end="1551"&gt;&lt;strong data-start="1537" data-end="1551"&gt;Resolución&lt;/strong&gt;&lt;/p&gt;
&lt;ul data-start="1555" data-end="1752"&gt;
&lt;li data-start="1555" data-end="1672"&gt;
&lt;p data-start="1557" data-end="1672"&gt;Si se verifica la infracción, se aplican sanciones, se ordenan medidas correctivas o se inicia un proceso judicial.&lt;/p&gt;
&lt;/li&gt;
&lt;li data-start="1676" data-end="1752"&gt;
&lt;p data-start="1678" data-end="1752"&gt;Si no se comprueba el hecho, se archiva el caso con justificación técnica.&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;</bpmn2:documentation>
      <bpmn2:incoming>Flow_0c6zlb3</bpmn2:incoming>
      <bpmn2:outgoing>Flow_1ljjexl</bpmn2:outgoing>
    </bpmn2:userTask>
    <bpmn2:userTask id="Informar_situacion_a_JP" name="Informar situación a JP" bizuit:Performers="Inspector" bizuit:AttachmentsCollection="[]" bizuit:Accountable="" bizuit:Consulted="" bizuit:Informed="">
      <bpmn2:documentation>&lt;p data-start="1317" data-end="1334"&gt;&lt;strong data-start="1317" data-end="1334"&gt;Investigación&lt;/strong&gt;&lt;/p&gt;
&lt;ul data-start="1338" data-end="1532"&gt;
&lt;li data-start="1338" data-end="1394"&gt;
&lt;p data-start="1340" data-end="1394"&gt;Se realiza trabajo de campo para verificar los hechos.&lt;/p&gt;
&lt;/li&gt;
&lt;li data-start="1398" data-end="1464"&gt;
&lt;p data-start="1400" data-end="1464"&gt;Se recolecta evidencia (fotos, videos, mediciones, testimonios).&lt;/p&gt;
&lt;/li&gt;
&lt;li data-start="1468" data-end="1532"&gt;
&lt;p data-start="1470" data-end="1532"&gt;Se evalúan posibles incumplimientos de normativas ambientales.&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;</bpmn2:documentation>
      <bpmn2:incoming>Flow_1ayrpd8</bpmn2:incoming>
      <bpmn2:outgoing>Flow_0rk9gfz</bpmn2:outgoing>
    </bpmn2:userTask>
    <bpmn2:dataObjectReference id="Acta_de_Infraccion" name="Acta de Infracción" dataObjectRef="DataObject_0fzxutw" />
    <bpmn2:dataObject id="DataObject_0fzxutw" />
    <bpmn2:dataStoreReference id="Denuncias" name="Denuncias" />
    <bpmn2:dataStoreReference id="Expedientes" name="Expedientes" />
    <bpmn2:dataStoreReference id="Inspectores" name="Inspectores" />
  </bpmn2:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Collaboration_150wd7z">
      <bpmndi:BPMNShape id="Participant_1lwdsfm_di" bpmnElement="Gestionar_Denuncia_Ambiental" isHorizontal="true">
        <dc:Bounds x="-298" y="110" width="1928" height="760" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_1d7k8j8_di" bpmnElement="Inspector" isHorizontal="true">
        <dc:Bounds x="-268" y="650" width="1898" height="220" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_1fmxwrw_di" bpmnElement="Jefe" isHorizontal="true">
        <dc:Bounds x="-268" y="450" width="1898" height="200" />
